# AI_PROVIDER: "baseui" or "openai-compatible" uses the /v1/chat/completions API.
# For Gemini fallback, set AI_PROVIDER="gemini" and GEMINI_API_KEY instead.
AI_PROVIDER=baseui
AI_BASE_URL=https://api.example.com/v1
AI_API_KEY=YOUR_AI_API_KEY
AI_MODEL=gpt-5.4-mini
AI_TIMEOUT_MS=20000

# Cloud account/session configuration.
# Production must use a long random secret and a durable data path or database-backed adapter.
SAAS_SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
SAAS_DATA_FILE=.data/saas-store.json
DATABASE_URL=
BILLING_WEBHOOK_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_BILLING_WEBHOOK_SECRET
REGISTRATION_INVITE_CODE=CHANGE_ME_TO_A_PRIVATE_REGISTRATION_CODE
AUTH_RATE_LIMIT_PER_MINUTE=60

# Production docker-compose PostgreSQL settings.
POSTGRES_DB=english_training
POSTGRES_USER=english_training
POSTGRES_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_POSTGRES_PASSWORD

# Optional Gemini fallback.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=MY_APP_URL
