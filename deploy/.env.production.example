AI_PROVIDER=baseui
AI_BASE_URL=https://api.psydo.top/v1
AI_API_KEY=replace-with-production-ai-key
AI_MODEL=gpt-5.4-mini
AI_TIMEOUT_MS=20000

APP_URL=https://study.xmlga.top
SAAS_SESSION_SECRET=replace-with-a-long-random-session-secret
BILLING_WEBHOOK_SECRET=replace-with-a-long-random-billing-secret

POSTGRES_DB=english_training
POSTGRES_USER=english_training
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password

# Required for GA/public promotion. The app signs each payload with
# x-english-email-signature when EMAIL_DELIVERY_WEBHOOK_SECRET is set.
EMAIL_DELIVERY_WEBHOOK_URL=
EMAIL_DELIVERY_WEBHOOK_SECRET=
ALLOW_DEVELOPMENT_EMAIL_TOKENS=false
TLS_EMAIL=admin@xmlga.top
HOST_APP_PORT=3312
